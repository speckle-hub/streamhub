generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String    @id
  createdAt     DateTime  @default(now())
  ageVerified   Boolean   @default(false)
  verifiedAt    DateTime?
  settings      String    @default("{}")
  
  // Relations
  watchProgress WatchProgress[]
  watchlist     Watchlist[]
  nsfwProgress  NsfwWatchProgress[]
  nsfwWatchlist NsfwWatchlist[]
  
  // NSFW settings
  nsfwPinHash   String?   
  nsfwSettings  String    @default("{}")
}

model Content {
  id            String    @id  // tmdb:123 or imdb:tt123
  type          String    // movie | tv
  title         String
  overview      String?
  posterPath    String?
  backdropPath  String?
  releaseDate   DateTime?
  rating        Float?
  genres        String    
  
  numberOfSeasons   Int?
  episodeRunTime    String?   
  
  updatedAt     DateTime  @updatedAt
  
  // Relations
  watchProgress WatchProgress[]
  watchlist     Watchlist[]
}

model WatchProgress {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId     String
  content       Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  seasonNumber  Int?
  episodeNumber Int?
  episodeTitle  String?
  
  position      Int       
  duration      Int
  percent       Float     
  completed     Boolean   @default(false)
  updatedAt     DateTime  @updatedAt
  
  @@unique([userId, contentId, seasonNumber, episodeNumber], name: "progress_id")
}

model Watchlist {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId     String
  content       Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  contentType   String    // movie | tv | anime
  sourceAddon   String?   // addon id
  watchStatus   String    @default("watch_later") // watch_later, watching, finished, dropped
  addedAt       DateTime  @default(now())
  
  @@unique([userId, contentId], name: "watchlist_unique")
}

model NsfwWatchProgress {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId     String
  contentType   String
  title         String?
  
  position      Int
  duration      Int
  updatedAt     DateTime  @updatedAt
}

model NsfwWatchlist {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId     String    // usually stremio internal ID
  contentType   String    // adult | hentai
  title         String?
  poster        String?
  sourceAddon   String?
  
  watchStatus   String    @default("watch_later") 
  addedAt       DateTime  @default(now())
  
  @@unique([userId, contentId], name: "nsfw_watchlist_unique")
}
