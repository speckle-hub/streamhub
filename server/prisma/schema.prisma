generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id            String    @id
  createdAt     DateTime  @default(now())
  ageVerified   Boolean   @default(false)
  verifiedAt    DateTime?
  settings      String    @default("{}") // SQLite doesn't support Json, use string
  
  // Relations
  watchProgress WatchProgress[]
  watchlist     Watchlist[]
  nsfwProgress  NsfwWatchProgress[]
  
  // NSFW settings
  nsfwPinHash   String?   // bcrypt hash, optional
  nsfwSettings  String    @default("{}") // SQLite stringified JSON
}

model Content {
  // Cache TMDB data for fast queries
  id            String    @id  // tmdb:123 or imdb:tt123
  type          String    // movie | tv
  title         String
  overview      String?
  posterPath    String?
  backdropPath  String?
  releaseDate   DateTime?
  rating        Float?
  genres        String    // SQLite doesn't support String[], use stringified JSON or comma-separated
  
  // For TV shows
  numberOfSeasons   Int?
  episodeRunTime    String?   // Comma-separated or JSON string
  
  updatedAt     DateTime  @updatedAt
  
  // Relations
  watchProgress WatchProgress[]
  watchlist     Watchlist[]
}

model WatchProgress {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId     String
  content       Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  // For TV episodes
  seasonNumber  Int?
  episodeNumber Int?
  episodeTitle  String?
  
  position      Int       // seconds
  duration      Int
  percent       Float     // 0-100, computed
  completed     Boolean   @default(false)
  updatedAt     DateTime  @updatedAt
  
  @@unique([userId, contentId, seasonNumber, episodeNumber], name: "progress_id")
}

model Watchlist {
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId     String
  content       Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  addedAt       DateTime  @default(now())
  
  @@id([userId, contentId], name: "watchlist_id")
}

model NsfwWatchProgress {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId     String
  contentType   String
  title         String?
  
  position      Int
  duration      Int
  updatedAt     DateTime  @updatedAt
}
